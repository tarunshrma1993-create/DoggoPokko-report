# Copy this file to ".env" and fill in values. ".env" is gitignored.
# Never put real tokens here — this file is safe to commit.
#
#   cp .env.example .env

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Optional
# INSTAGRAM_GRAPH_VERSION=v21.0
# How many media items to fetch (paginated) — higher finds true top-view Reels (e.g. 5M+). Max 5000.
# MAX_MEDIA_FETCH=500
# Legacy alias: MAX_POSTS (same as MAX_MEDIA_FETCH if set)
# KPI + engagement headline uses only the N most recent posts:
# KPI_SAMPLE_POSTS=50
# Rows in the HTML table (most recent):
# TABLE_POSTS=50
# Cards in “Latest reels” grid (top of list by views):
# REELS_GRID_LIMIT=50
# INSIGHT_DELAY=0.12
# Shown in the HTML <title> when set (e.g. after you publish to your domain)
# SITE_DOMAIN=doggopokko.com
#
# Optional: deploy dist/ via FTP (GoDaddy cPanel → FTP Accounts)
# GODADDY_FTP_HOST=ftp.doggopokko.com
# GODADDY_FTP_USER=
# GODADDY_FTP_PASSWORD=
# GODADDY_FTP_REMOTE_DIR=public_html
# GODADDY_FTP_PORT=21
